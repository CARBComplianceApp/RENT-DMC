{
  "entities": {
    "userSettings": {
      "title": "User Settings",
      "description": "Tenant-specific settings and preferences",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "unit": { "type": "string" },
        "mailboxColor": { "type": "string", "description": "Hex color code for the mailbox icon" },
        "preferred_notification_time": { "type": "string" },
        "sms_enabled": { "type": "boolean" },
        "email_enabled": { "type": "boolean" }
      },
      "required": ["uid", "unit"]
    },
    "mailboxCustomizations": {
      "title": "Mailbox Customizations",
      "description": "Publicly visible mailbox customizations (anonymized)",
      "type": "object",
      "properties": {
        "unit": { "type": "string" },
        "color": { "type": "string" }
      },
      "required": ["unit", "color"]
    }
  },
  "firestore": {
    "/userSettings/{uid}": {
      "schema": "userSettings",
      "description": "Private user settings"
    },
    "/mailboxCustomizations/{unit}": {
      "schema": "mailboxCustomizations",
      "description": "Publicly visible mailbox customizations"
    }
  }
}
